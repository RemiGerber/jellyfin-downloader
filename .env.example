# Only set what you want to override — all values have defaults.

# Docker image name and tag to pull (default: ubbrelf/jellyfin-downloader:latest)
DOCKER_IMAGE=
DOCKER_TAG=

# Host port to access the app on (default: 3003)
HOST_PORT=

# Path to your media library on the host machine (default: /mnt/nas)
MEDIA_FOLDER=

# Where to persist app data across restarts (default: jellyfin-downloader-data named Docker volume)
# Set to an absolute host path to use a folder instead (e.g. APP_DATA=/home/user/.jellyfin-downloader)
APP_DATA=

# Path to a folder containing WireGuard .conf files for VPN support (default: ./vpn)
# Create the folder and drop standard WireGuard config files inside:
#   mkdir -p ./vpn
#   cp ~/Downloads/us-east.conf ./vpn/
# Profiles appear in the 🔒 VPN panel in the web UI.
VPN_CONFIGS=
